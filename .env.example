###############################################################################
# Cognee Example Environment Configuration
# 
# Copy this file to .env and fill in your actual values
# This example shows configuration for:
# - OpenAI-compatible LLM (like DeepSeek, GLM, etc.) via JD Cloud
# - Ollama for local embeddings
# - Rate limiting enabled
###############################################################################

################################################################################
#  🧠 LLM Settings
################################################################################

# Currently we support BAML and Instructor(using litellm) for structured outputs
STRUCTURED_OUTPUT_FRAMEWORK="instructor"

# Your LLM API key
LLM_API_KEY="your_api_key_here"

# Model name (use openai/ prefix for OpenAI-compatible APIs)
LLM_MODEL="openai/DeepSeek-V3.2"

# LLM provider (openai, ollama, anthropic, etc.)
LLM_PROVIDER="openai"

# OpenAI-compatible endpoint (e.g., JD Cloud, OpenRouter, custom endpoint)
LLM_ENDPOINT="https://modelservice.jdcloud.com/coding/openai/v1"

LLM_API_VERSION=""

# Max tokens for LLM response
LLM_MAX_TOKENS="1024"

# Instructor mode for structured output
# Options: "json_schema_mode", "json_mode", "tool_calling", "markdown"
# Use "json_mode" for DeepSeek and other models that don't support JSON schema
LLM_INSTRUCTOR_MODE="json_mode"


################################################################################
#  ⚡ Rate Limiting
################################################################################
# Enable rate limiting to avoid hitting API limits
LLM_RATE_LIMIT_ENABLED=true
LLM_RATE_LIMIT_REQUESTS=1
LLM_RATE_LIMIT_INTERVAL=60

EMBEDDING_RATE_LIMIT_ENABLED=true
EMBEDDING_RATE_LIMIT_REQUESTS=1
EMBEDDING_RATE_LIMIT_INTERVAL=60


################################################################################
#  📝 Extra LLM Arguments
################################################################################
# Extra kwargs passed to every LLM completion call (JSON string)
LLM_ARGS='{"max_tokens": 8192}'


################################################################################
#  🔢 Embedding Settings
################################################################################

# Embedding provider: ollama, openai, litellm, etc.
EMBEDDING_PROVIDER="ollama"

# Embedding model (must match an Ollama model you have pulled)
EMBEDDING_MODEL="mxbai-embed-large:latest"

# Ollama embedding endpoint (note: must include /api/embed path)
EMBEDDING_ENDPOINT="http://127.0.0.1:11434/api/embed"

EMBEDDING_API_VERSION=""

# Tokenizer for embedding (optional, used by some providers)
HUGGINGFACE_TOKENIZER="bert-base-uncased"

# Max tokens per embedding chunk (important for Ollama mxbai-embed-large)
# Default: 512 (safe for most embedding models)
EMBEDDING_MAX_TOKENS=512

# Embedding dimensions (uncomment if needed)
# EMBEDDING_DIMENSIONS=3072


################################################################################
#  🗄️ Database Settings (optional)
################################################################################

# Default: SQLite
# DB_PROVIDER="sqlite"
# DB_NAME=cognee_db


################################################################################
#  ☁️ Storage Backend (optional)
################################################################################

# Default: local filesystem
# STORAGE_BACKEND="local"